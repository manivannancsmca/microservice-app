### ============================================================================
### Order Service REST APIs
### Base URL
### ============================================================================

@host = http://localhost:8013
@baseUrl = {{host}}/api/v1/orders
@contentType = application/json

### ============================================================================
### Health Check
### ============================================================================

GET {{host}}/actuator/health
Accept: application/json

###

### ============================================================================
### Get All Orders (Default Pagination)
### ============================================================================

GET {{baseUrl}}
Accept: application/json

###

### ============================================================================
### Get All Orders - Page 0
### ============================================================================

GET {{baseUrl}}?page=0&size=10
Accept: application/json

###

### ============================================================================
### Get All Orders - Page 1
### ============================================================================

GET {{baseUrl}}?page=1&size=10
Accept: application/json

###

### ============================================================================
### Get Orders - Sort by ID ASC
### ============================================================================

GET {{baseUrl}}?page=0&size=10&sort=id,asc
Accept: application/json

###

### ============================================================================
### Get Orders - Sort by ID DESC
### ============================================================================

GET {{baseUrl}}?page=0&size=10&sort=id,desc
Accept: application/json

###

### ============================================================================
### Get Orders - Sort by Total Price DESC
### ============================================================================

GET {{baseUrl}}?page=0&size=10&sort=totalPrice,desc
Accept: application/json

###

### ============================================================================
### Get Orders - Sort by Created Date DESC
### ============================================================================

GET {{baseUrl}}?page=0&size=10&sort=createdAt,desc
Accept: application/json

###

### ============================================================================
### Get Orders - Multiple Sorting
### ============================================================================

GET {{baseUrl}}?page=0&size=10&sort=orderStatus,asc&sort=createdAt,desc
Accept: application/json

###

### ============================================================================
### Get Order By Id
### ============================================================================

GET {{baseUrl}}/1
Accept: application/json

###

### ============================================================================
### Create Order
### ============================================================================

POST {{baseUrl}}
Content-Type: {{contentType}}
Accept: application/json

{
  "userId": 102,
  "productId": 10,
  "quantity": 5
}

###

### ============================================================================
### Update Order
### ============================================================================

PUT {{baseUrl}}/1
Content-Type: {{contentType}}
Accept: application/json

{
  "userId": 101,
  "productId": 1005,
  "quantity": 4
}

###

### ============================================================================
### Update Order Status
### ============================================================================

PATCH {{baseUrl}}/1/status
Content-Type: {{contentType}}
Accept: application/json

{
  "orderStatus": "SHIPPED"
}

###

### ============================================================================
### Delete Order
### ============================================================================

DELETE {{baseUrl}}/1
Accept: application/json

###

### ============================================================================
### Search Orders by User
### ============================================================================

GET {{baseUrl}}/users/102
Accept: application/json

###

### ============================================================================
### Search Orders by Product
### ============================================================================

GET {{baseUrl}}/products/1001
Accept: application/json

###

### ============================================================================
### Search Orders by Status
### ============================================================================

GET {{baseUrl}}/status/DELIVERED
Accept: application/json

###

### ============================================================================
### Search Orders Between Dates
### ============================================================================

GET {{baseUrl}}/search?from=2026-07-01&to=2026-07-31
Accept: application/json

###